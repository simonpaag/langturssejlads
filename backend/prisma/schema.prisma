// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  passwordHash   String
  name           String
  profileImage   String?
  isSystemAdmin  Boolean   @default(false)
  
  crewMemberships CrewMember[]
  posts           Post[]
}

model Boat {
  id           Int       @id @default(autoincrement())
  slug         String    @unique
  name         String
  description  String?
  coverImage   String?
  profileImage String?
  
  crewMemberships CrewMember[]
  posts           Post[]
  voyages         Voyage[]
}

model CrewMember {
  user     User     @relation(fields: [userId], references: [id])
  userId   Int
  boat     Boat     @relation(fields: [boatId], references: [id])
  boatId   Int
  role     String   // 'BOAT_ADMIN' | 'BOAT_AUTHOR'

  @@id([userId, boatId])
}

enum PostType {
  ARTICLE
  QUICK_TEXT
  YOUTUBE
  PHOTO
  VOYAGE_UPDATE
}

model Post {
  id          Int           @id @default(autoincrement())
  slug        String        @unique // Used for ARTICLE routing, or unique generic ID for others
  postType    PostType      @default(ARTICLE)
  title       String?       // Used by ARTICLE and VOYAGE_UPDATE
  content     String?       // Body text/HTML
  youtubeUrl  String?
  imageUrl    String?       // Image for PHOTO or Cover for ARTICLE
  status      String        @default("DRAFT") // 'DRAFT' | 'APPROVED' | 'PUBLISHED' | 'REJECTED'
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author      User          @relation(fields: [authorId], references: [id])
  authorId    Int
  
  boat        Boat          @relation(fields: [boatId], references: [id])
  boatId      Int

  voyage      Voyage?       @relation(fields: [voyageId], references: [id])
  voyageId    Int?
}

model Voyage {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?     // Null means ongoing
  fromLocation String?
  toLocation   String?
  imageUrl     String?
  availableSeats Int       @default(0)
  
  boat        Boat          @relation(fields: [boatId], references: [id])
  boatId      Int

  posts       Post[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
