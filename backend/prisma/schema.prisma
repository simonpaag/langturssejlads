// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  passwordHash   String
  name           String
  profileImage   String?
  isSystemAdmin  Boolean   @default(false)
  interests      String[]
  
  crewMemberships CrewMember[]
  posts           Post[]
  votes           Vote[]
  boardMessages   BoardMessage[]
}

model Boat {
  id           Int       @id @default(autoincrement())
  slug         String    @unique
  name         String
  description  String?
  coverImage   String?
  profileImage String?
  websiteUrl   String?
  socialLinks  Json?     // [{ platform: 'Instagram', url: '...' }]
  isBoardPublic Boolean  @default(true)
  
  // Specs
  boatModel    String?   // Model
  length       Float     @default(0) // Længde (i fod) - Required
  width        Float?    // Bredde (i meter)
  tonnage      Int?      // Brutto tonnage (i kilo)
  bunks        Int?      // Antal køjer (sovende personer)
  
  crewMemberships CrewMember[]
  posts           Post[]
  voyages         Voyage[]
  boardMessages   BoardMessage[]
}

model CrewMember {
  user     User     @relation(fields: [userId], references: [id])
  userId   Int
  boat     Boat     @relation(fields: [boatId], references: [id])
  boatId   Int
  role     String   // 'BOAT_ADMIN' | 'BOAT_AUTHOR'

  @@id([userId, boatId])
}

enum PostType {
  ARTICLE
  QUICK_TEXT
  YOUTUBE
  PHOTO
  VOYAGE_UPDATE
}

model Post {
  id          Int           @id @default(autoincrement())
  slug        String        @unique // Used for ARTICLE routing, or unique generic ID for others
  postType    PostType      @default(ARTICLE)
  title       String?       // Used by ARTICLE and VOYAGE_UPDATE
  content     String?       // Body text/HTML
  youtubeUrl  String?
  imageUrl    String?       // Image for PHOTO or Cover for ARTICLE
  status      String        @default("DRAFT") // 'DRAFT' | 'APPROVED' | 'PUBLISHED' | 'REJECTED'
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author      User          @relation(fields: [authorId], references: [id])
  authorId    Int
  
  boat        Boat          @relation(fields: [boatId], references: [id])
  boatId      Int

  voyage      Voyage?       @relation(fields: [voyageId], references: [id])
  voyageId    Int?

  votes       Vote[]
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

model Vote {
  id        Int      @id @default(autoincrement())
  type      VoteType
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  
  post      Post     @relation(fields: [postId], references: [id])
  postId    Int

  @@unique([userId, postId])
}

model BoardMessage {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  
  boatId    Int
  boat      Boat     @relation(fields: [boatId], references: [id], onDelete: Cascade)
}

model Voyage {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?     // Null means ongoing
  fromLocation String?
  toLocation   String?
  imageUrl     String?
  availableSeats Int       @default(0)
  
  boat        Boat          @relation(fields: [boatId], references: [id])
  boatId      Int

  posts       Post[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
